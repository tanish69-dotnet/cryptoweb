<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Kinetic Ledger</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        headline: ['"Space Grotesk"', 'sans-serif'],
                        body: ['"Plus Jakarta Sans"', 'sans-serif'],
                        label: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        primary: '#a1faff',
                        secondary: '#3fff8b',
                        surface: '#07090b',
                        'surface-container': '#0b0e11',
                        'surface-container-high': '#111418',
                        'surface-container-highest': '#1c2024',
                        'on-surface': '#f8f9fe',
                        'on-surface-variant': '#8f9fb8',
                        'on-primary': '#00373a',
                        'outline': '#2d333b',
                        'outline-variant': '#1c2024',
                        error: '#ff716c',
                        'error-container': '#410002',
                        'on-error': '#ffffff',
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary/30">

<%- include('partials/sidebar', { currentPath: currentPath }) %>

<!-- Main Content Canvas -->
<main class="xl:pl-64 pt-8 min-h-screen flex items-center justify-center">
    <div class="text-center p-8 relative">
        <div class="absolute inset-0 bg-primary/5 blur-[120px] rounded-full z-0"></div>
        <div class="relative z-10">
            <span class="material-symbols-outlined text-[100px] mb-8 bg-gradient-to-b from-primary/60 to-transparent bg-clip-text text-transparent block">construction</span>
            <h1 class="text-4xl lg:text-5xl font-headline font-bold mb-6 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent transform transition-all hover:scale-105"><%= title %></h1>
            <p class="text-on-surface-variant text-lg max-w-md mx-auto mb-10 leading-relaxed font-label">The <%= title %> module is currently undergoing heavy infrastructure deployment. Return soon for the Kinetic V2 release.</p>
            <a href="/" class="inline-flex items-center gap-3 bg-surface-container-highest text-primary active:scale-95 border border-primary/20 px-8 py-3 rounded-2xl font-bold hover:scale-[1.02] transition-transform hover:shadow-[0_0_30px_rgba(161,250,255,0.15)] group">
                <span class="material-symbols-outlined text-xl group-hover:-translate-x-1 transition-transform">arrow_back</span>
                Return to Dashboard
            </a>
        </div>
    </div>
</main>
</body></html>
