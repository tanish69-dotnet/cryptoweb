<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio | Kinetic Ledger</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        headline: ['"Space Grotesk"', 'sans-serif'],
                        body: ['"Plus Jakarta Sans"', 'sans-serif'],
                        label: ['"Plus Jakarta Sans"', 'sans-serif'],
                    },
                    colors: {
                        primary: '#a1faff',
                        secondary: '#3fff8b',
                        surface: '#07090b',
                        'surface-container': '#0b0e11',
                        'surface-container-high': '#111418',
                        'surface-container-highest': '#1c2024',
                        'on-surface': '#f8f9fe',
                        'on-surface-variant': '#8f9fb8',
                        'on-primary': '#00373a',
                        'outline': '#2d333b',
                        'outline-variant': '#1c2024',
                        error: '#ff716c',
                        'error-container': '#410002',
                        'on-error': '#ffffff',
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary/30">

<%- include('partials/sidebar', { currentPath: currentPath }) %>

<!-- Main Content Canvas -->
<main class="xl:pl-64 pt-12 min-h-screen px-8 max-w-[1400px] mx-auto pb-20">
    <h1 class="text-3xl font-headline font-bold mb-8">Asset Portfolio</h1>
    
    <!-- Total Balance Hero -->
    <div class="relative bg-surface-container-highest rounded-3xl p-10 overflow-hidden mb-12 border border-outline-variant/30">
        <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 blur-[100px] rounded-full -translate-y-1/2 translate-x-1/3"></div>
        <div class="relative z-10">
            <span class="text-on-surface-variant font-label text-sm uppercase tracking-wider font-bold mb-2 block">Total Balance (USD)</span>
            <div class="flex items-end gap-4 mb-4">
                <h2 class="text-5xl lg:text-7xl font-headline font-bold tracking-tight" id="total-balance">$0.00</h2>
                <div class="bg-secondary/10 text-secondary px-3 py-1.5 rounded-lg flex items-center gap-1 mb-2">
                    <span class="material-symbols-outlined text-sm font-bold">arrow_upward</span>
                    <span class="text-sm font-bold">+12.4% All Time</span>
                </div>
            </div>
            <p class="text-on-surface-variant text-sm">Live market valuation based on Kinetic API aggregated feeds.</p>
        </div>
    </div>

    <!-- Holdings Table -->
    <h3 class="font-headline font-bold text-xl mb-6">Your Holdings</h3>
    <div class="bg-surface-container rounded-3xl border border-outline-variant/10 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-outline-variant/10 text-xs font-label text-on-surface-variant uppercase tracking-wider">
                    <th class="px-8 py-5 font-bold">Asset</th>
                    <th class="px-8 py-5 font-bold">Balance</th>
                    <th class="px-8 py-5 font-bold">Live Market Price</th>
                    <th class="px-8 py-5 font-bold text-right">Total USD Value</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/5" id="holdings-list">
                <!-- Data populated dynamically by JavaScript -->
            </tbody>
        </table>
    </div>
</main>

<script src="/portfolio.js"></script>
</body>
</html>
